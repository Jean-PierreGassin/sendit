{
  "name": "@globb/sendit",
  "version": "0.1.0",
  "description": "Send files from the terminal through pluggable transfer engines (AirDrop on macOS)",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Jean-PierreGassin/sendit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jean-PierreGassin/sendit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Jean-PierreGassin/sendit/issues"
  },
  "keywords": [
    "airdrop",
    "file-transfer",
    "cli",
    "macos",
    "send"
  ],
  "bin": {
    "sendit": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@globb/airdrop": "workspace:*",
    "commander": "^14.0.2",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
